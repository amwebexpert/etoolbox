{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(npm *)",
            "description": "Block npm and promote bun to prevent package version conflicts",
            "command": "npx --yes tsx \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-npm-prefer-bun.gate.ts"
          },
          {
            "type": "command",
            "if": "Bash(yarn *)",
            "description": "Block yarn and promote bun to prevent package version conflicts",
            "command": "npx --yes tsx \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-npm-prefer-bun.gate.ts"
          },
          {
            "type": "command",
            "if": "Bash(git push *)",
            "description": "Block force-pushing to protected branches (main, master, develop)",
            "command": "npx --yes tsx \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/block-force-push.gate.ts"
          }
        ]
      }
    ]
  }
}
